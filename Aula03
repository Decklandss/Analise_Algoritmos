
def substrings(s, inicio=0, fim=0):
    
    
    if inicio == len(s):
        return
    
    if fim > len(s):
        # Move o início para frente e reinicia o fim
        substrings(s, inicio + 1, inicio + 1)
        return
    
    
    print(s[inicio:fim])
    
    
    substrings(s, inicio, fim + 1)


