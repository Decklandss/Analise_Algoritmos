import math

def teorema_mestre(a, b, k, p):
    logba = math.log(a, b)

    print(f"\nT(n) = {a}T(n/{b}) + n^{k} * (log n)^{p}")
    print(f"log_b(a) = {logba:.4f}")

    if abs(k - logba) < 1e-6:
        print("Caso 2 do Teorema Mestre")
        print(f"T(n) = Theta(n^{logba:.4f} * (log n)^{p+1})")

    elif k < logba:
        print("Caso 1 do Teorema Mestre")
        print(f"T(n) = Theta(n^{logba:.4f})")

    else:
        print("Caso 3 do Teorema Mestre")
        print(f"T(n) = Theta(n^{k} * (log n)^{p})")


