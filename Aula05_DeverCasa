print("===== MERGE SORT =====")
teorema_mestre(a=2, b=2, k=1, p=0)

print("\n===== MULTIPLICAÇÃO DE MATRIZES =====")
print("Método tradicional:")
teorema_mestre(a=8, b=2, k=2, p=0)

print("\nMétodo de Strassen:")
teorema_mestre(a=7, b=2, k=2, p=0)

print("\n===== RECORRÊNCIAS =====")

print("\n(a)")
teorema_mestre(a=2, b=4, k=0.5, p=0)

print("\n(b)")
teorema_mestre(a=2, b=4, k=1, p=0)

print("\n(c)")
teorema_mestre(a=16, b=4, k=2, p=0)